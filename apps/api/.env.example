DATABASE_URL="postgresql://vms:vms_password@localhost:5432/vms_db?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
API_PORT=3000
# Inclua aqui os dominios/IPs reais do frontend em producao.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CAMERA_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
FFMPEG_RTSP_TRANSPORT=tcp
FFMPEG_STIMEOUT_US=8000000
FFMPEG_MAX_DELAY_US=500000
FFMPEG_PROBESIZE=32768
FFMPEG_ANALYZEDURATION_US=1000000
MJPEG_FPS=20
MJPEG_Q=5
RECORDINGS_ROOT=./storage/recordings
STORAGE_BACKEND=local
STORAGE_WRITE_PROBE_ENABLED=true
RECORDING_SEGMENT_SECONDS=300
FFMPEG_RECORDING_FORMAT=mp4
FFMPEG_RECORDING_COPY_CODEC=true
RETENTION_DAYS=7
RECORDING_RETENTION_DAYS=7
RETENTION_USE_BULLMQ=true
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=8h
EVIDENCE_HMAC_SECRET=REPLACE_WITH_STRONG_EVIDENCE_HMAC_SECRET_MIN_32_CHARS
EVIDENCE_HMAC_KEY_ID=local-v1
ALARM_WEBHOOK_DEFAULT_URL=
ALARM_WEBHOOK_ALLOWED_HOSTS=
ALARM_WEBHOOK_SIGNING_SECRET=
ALARM_EMAIL_FROM=
AI_BASE_URL=http://ai-service:8000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
STREAM_TOKEN_EXPIRES_IN=5m
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD_MIN_10_CHARS
ADMIN_NAME=Administrador
SEED_SAMPLE_USERS=false
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_SAMPLE_ADMIN_PASSWORD_MIN_10_CHARS
SEED_OPERATOR_PASSWORD=REPLACE_WITH_STRONG_SAMPLE_OPERATOR_PASSWORD_MIN_10_CHARS
SEED_VIEWER_PASSWORD=REPLACE_WITH_STRONG_SAMPLE_VIEWER_PASSWORD_MIN_10_CHARS
CAMERA_TEST_ALLOW_PUBLIC_IP=false
