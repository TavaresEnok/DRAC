{
  "expo": {
    "name": "DRAC Mobile",
    "slug": "drac-mobile",
    "version": "1.0.5",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071013"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ajustconsulting.dracmobile",
      "versionCode": 6,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071013"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-notifications",
        {
          "color": "#EF4444"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permite salvar fotos e clipes das câmeras na galeria.",
          "savePhotosPermission": "Permite salvar fotos e clipes das câmeras na galeria.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c5d88e7a-5932-4bf2-998e-97d989a2e15f"
      }
    }
  }
}
