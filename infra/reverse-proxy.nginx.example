# Example reverse proxy for DRAC VMS.
# Replace drac.example.com and certificate paths before using.

map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

server {
  listen 80;
  server_name drac.example.com;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name drac.example.com;

  ssl_certificate /etc/letsencrypt/live/drac.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/drac.example.com/privkey.pem;

  client_max_body_size 512m;

  location / {
    proxy_pass http://127.0.0.1:5173;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
  }

  location /api/ {
    proxy_pass http://127.0.0.1:3000/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
  }

  # Optional: MediaMTX WebRTC HTTP signaling through the same domain.
  # UDP media still needs port 8189/udp reachable unless you configure TURN.
  location /webrtc/ {
    proxy_pass http://127.0.0.1:8889/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
  }
}
