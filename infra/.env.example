POSTGRES_USER=vms
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=vms_db
POSTGRES_BACKUP_RETENTION_DAYS=14
POSTGRES_BACKUP_INTERVAL_SECONDS=86400

JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
CAMERA_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_STRONG_INTERNAL_TOKEN_MIN_24_CHARS
EVIDENCE_HMAC_SECRET=REPLACE_WITH_STRONG_EVIDENCE_HMAC_SECRET_MIN_32_CHARS
EVIDENCE_HMAC_KEY_ID=local-v1
# Inclua aqui os dominios/IPs reais do frontend em producao.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_APP_URL=http://127.0.0.1:5173
API_PUBLIC_URL=http://127.0.0.1:3000
VITE_API_URL=

# Rotacao de logs dos containers. Evita disco cheio por logs longos.
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILES=5

# ── DRAC Central / conector cloud ──────────────────────────────
# Desligado por padrao. Ative apenas quando esta instalacao local
# deve enviar heartbeat e metricas para o painel central.
CLOUD_CONNECTOR_ENABLED=false
CLOUD_API_URL=http://127.0.0.1:9765
CLOUD_INSTALLATION_ID=
CLOUD_LICENSE_KEY=
CLOUD_CUSTOMER_NAME=
CLOUD_HEARTBEAT_INTERVAL_SECONDS=60
CLOUD_CONNECTOR_TIMEOUT_MS=8000
DRAC_VERSION=local
DRAC_LAUNCH_PROFILE=standard

# Binds usados por infra/docker-compose.prod.yml.
DRAC_API_BIND=127.0.0.1
DRAC_WEB_BIND=127.0.0.1
DRAC_POSTGRES_BIND=127.0.0.1
DRAC_REDIS_BIND=127.0.0.1
DRAC_MEDIAMTX_RTSP_BIND=127.0.0.1
DRAC_MEDIAMTX_HLS_BIND=127.0.0.1
DRAC_MEDIAMTX_WEBRTC_HTTP_BIND=0.0.0.0
DRAC_MEDIAMTX_WEBRTC_UDP_BIND=0.0.0.0

RETENTION_DAYS=7
RECORDING_RETENTION_DAYS=7
RECORDING_AUTO_START_ENABLED=false
RECORDING_AUTO_START_DELAY_MS=10000
RECORDING_DISK_GUARD_ENABLED=true
RECORDING_DISK_GUARD_INTERVAL_MS=30000
RECORDING_DISK_GUARD_MAX_USED_PERCENT=92
RETENTION_USE_BULLMQ=true

MEDIAMTX_API_BASE_URL=http://mediamtx:9997
MEDIAMTX_API_USER=change_me_mediamtx_user
MEDIAMTX_API_PASS=change_me_mediamtx_pass
MEDIAMTX_PUBLIC_HOST=
MEDIAMTX_PUBLIC_SCHEME=
MEDIAMTX_PUBLIC_WEBRTC_URL=
MEDIAMTX_PUBLIC_HLS_URL=
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
# Dev pode usar "*". Em producao, use a origem HTTPS real do frontend.
MEDIAMTX_HLS_ALLOW_ORIGIN=*
MEDIAMTX_WEBRTC_ALLOW_ORIGIN=*
MEDIAMTX_WEBRTC_ADDITIONAL_HOST=127.0.0.1
MEDIAMTX_WARM_PATHS_ON_BOOT=false
ALARM_WEBHOOK_ALLOWED_HOSTS=
ALARM_WEBHOOK_SIGNING_SECRET=
CAMERA_TEST_ALLOW_PUBLIC_IP=false

# ── IA: configuração geral ────────────────────────────────────
AI_AUTO_START_ENABLED=false
# A IA usa RTSP direto da câmera pelo analyticsSubtype; não usa MediaMTX/live.
AI_USE_MEDIAMTX=false
AI_RTSP_SUBTYPE=auto

# Modo global de IA: motion | face | general
# Alterar via API: PATCH /ai/settings {"mode": "face"}
# (ou defina o default aqui; a tabela AiSettings persiste no banco)

# Movimento, face e pessoa usam perfis fixos compilados no servico de IA.

# QoS de live (PR4)
AI_CPU_RESERVE_PERCENT=14
# vazio = automático por orçamento:
# ai_budget = floor(cpu_logical * (1 - reserve_percent / 100))
# workers ~ sqrt(ai_budget), threads/worker = floor(ai_budget/workers)
AI_INFERENCE_WORKER_COUNT=
AI_INFERENCE_THREADS_OVERRIDE=10
AI_SELECTED_DETECTION_FPS=3.0
AI_SELECTED_ANALYSIS_WIDTH=960
AI_SELECTED_ANALYSIS_HEIGHT=540
AI_SELECTED_IMGSZ=640
AI_GRID_DETECTION_FPS=1.0
AI_GRID_ANALYSIS_WIDTH=640
AI_GRID_ANALYSIS_HEIGHT=360
AI_GRID_IMGSZ=512
AI_QOS_LIVE_ENABLED=true

# Adaptação dinâmica suave (PR5)
AI_ADAPTIVE_MODE=true
AI_ADAPTIVE_PILOT_CAMERA_IDS=*
AI_ADAPTIVE_WINDOW_SECONDS=6
AI_ADAPTIVE_DEGRADE_COOLDOWN_SECONDS=8
AI_ADAPTIVE_RECOVER_COOLDOWN_SECONDS=15
AI_ADAPTIVE_DROP_RATIO_HIGH=0.12
AI_ADAPTIVE_DROP_RATIO_LOW=0.03
AI_ADAPTIVE_CPU_HIGH=88
AI_ADAPTIVE_CPU_LOW=68
AI_ADAPTIVE_SELECTED_FPS_FACTORS=1.0,0.85,0.70
AI_ADAPTIVE_GRID_FPS_FACTORS=1.0,0.85
AI_ADAPTIVE_SELECTED_IMGSZ_STEPS=640,512,416
AI_ADAPTIVE_GRID_IMGSZ_STEPS=512,416
AI_ADAPTIVE_SELECTED_RESOLUTION_SCALES=1.0,0.92,0.84,0.76
AI_ADAPTIVE_GRID_RESOLUTION_SCALES=1.0,0.90,0.80
