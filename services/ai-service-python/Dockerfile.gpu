# Variante GPU (NVIDIA/CUDA) do serviço de IA — DORMENTE.
# A imagem padrão (Dockerfile) continua em CPU e é a usada hoje. Esta só é
# construída quando se ativa a IA com GPU (ver docker-compose.gpu.yml + os
# "poucos passos" no README de GPU).
#
# Base CUDA runtime (cuDNN) compatível com onnxruntime-gpu 1.19.x (CUDA 12).
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /app

# Python 3.11 + libs de sistema do OpenCV/runtimes.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3-pip python3.11-dev \
    libgl1 libglib2.0-0 build-essential cmake wget \
 && rm -rf /var/lib/apt/lists/* \
 && ln -sf /usr/bin/python3.11 /usr/bin/python

COPY requirements-gpu.txt .
RUN pip install --no-cache-dir -r requirements-gpu.txt

RUN mkdir -p /app/models

ARG AI_SERVICE_SOURCE_REV=local
COPY . .

# Acelera por GPU quando o serviço sobe com estes runtimes (controlados pelo
# compose de GPU). Mantemos comentado aqui para a imagem não impor o modo GPU;
# o compose é quem liga via env, conforme os "poucos passos" de ativação.
# ENV GENERAL_RUNTIME=onnxruntime_cuda
# ENV FACE_RUNTIME=onnxruntime_cuda

ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

EXPOSE 8000
CMD ["python", "main.py"]
